# Copy to ".env" and adjust if you want non-default local credentials.
# docker-compose.yml falls back to these same values if no .env exists,
# so the stack runs out-of-the-box without this file. Dev-only values.

POSTGRES_DB=carrental
POSTGRES_USER=carrental
POSTGRES_PASSWORD=carrental

# Host port for the container's Postgres. Defaults to 55432 because native
# Postgres clusters already occupy 5432/5433 on this machine. Backend connects here.
POSTGRES_PORT=55432
