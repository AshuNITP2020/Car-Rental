# Template for the local .env (which is gitignored). Copy to ".env" and fill in.
# Used by BOTH docker-compose (Postgres) and the Spring backend
# (imported via spring.config.import in application.yml). Dev-only values.

# ── docker-compose: Postgres container ──────────────────────────────
POSTGRES_DB=carrental
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=55432

# ── backend: datasource (must match the Postgres creds above) ───────
DB_URL=jdbc:postgresql://localhost:55432/carrental
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ── JWT (use a long random value, >= 32 bytes) ──────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-bytes

# ── Kafka ───────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=car-rental

# ── Payments: 'mock' (no keys) or 'razorpay' (needs test keys) ──────
PAYMENTS_PROVIDER=mock
PAYMENTS_WEBHOOK_SECRET=dev-webhook-secret
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Pricing ─────────────────────────────────────────────────────────
PRICING_GST_PERCENT=18
PRICING_DEPOSIT_PERCENT=20
PRICING_PLATFORM_FEE_PERCENT=10

# ── Cancellation policy ─────────────────────────────────────────────
CANCELLATION_FREE_WINDOW_HOURS=24
CANCELLATION_LATE_REFUND_PERCENT=50

# ── Notifications: 'log' (no setup) or 'email' (needs MAIL_* below) ─
NOTIFICATIONS_PROVIDER=log
NOTIFICATIONS_EMAIL_FROM=no-reply@car-rental.local
MAIL_HOST=
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_AUTH=true
MAIL_STARTTLS=true

# ── Scheduler intervals (ms) / windows ──────────────────────────────
SCHED_HOLD_EXPIRY_MS=60000
SCHED_AUTO_COMPLETE_MS=300000
SCHED_REMINDER_MS=300000
SCHED_REMINDER_WINDOW_HOURS=24
SCHED_REPORT_CRON=0 0 1 * * *
